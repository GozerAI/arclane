# Arclane configuration
# Copy to .env and replace all placeholder values before production deploy.

# Environment
ARCLANE_ENV=production

# Database
# Development:
# ARCLANE_DATABASE_URL=sqlite+aiosqlite:///arclane.db
# Production:
POSTGRES_DB=arclane
POSTGRES_USER=arclane
POSTGRES_PASSWORD=change-me
ARCLANE_DATABASE_URL=postgresql+asyncpg://arclane:change-me@postgres:5432/arclane

# Security
ARCLANE_SECRET_KEY=change-me-in-production
ARCLANE_WEBHOOK_SIGNING_SECRET=change-me-webhook-secret

# Domain
ARCLANE_DOMAIN=arclane.cloud
ARCLANE_CADDY_ADMIN_URL=http://localhost:2019
ARCLANE_WORKSPACES_ROOT=/var/arclane/workspaces

# Orchestration
ARCLANE_ORCHESTRATION_MODE=internal
ARCLANE_LLM_BASE_URL=
ARCLANE_LLM_API_KEY=
ARCLANE_LLM_MODEL=
ARCLANE_LLM_TIMEOUT_S=60

# Bridge mode only
# ARCLANE_CSUITE_BASE_URL=http://csuite:8007

# Upstream services
ARCLANE_ZUULTIMATE_BASE_URL=http://zuultimate:8000
ARCLANE_VINZY_BASE_URL=http://vinzy:8001
ARCLANE_TRENDSCOPE_BASE_URL=http://trendscope:8002
ARCLANE_ZUUL_SERVICE_TOKEN=

# Billing
ARCLANE_STRIPE_ENABLED=false

# Email
ARCLANE_RESEND_API_KEY=
ARCLANE_EMAIL_FROM_DOMAIN=arclane.cloud

# OAuth
ARCLANE_GOOGLE_CLIENT_ID=
ARCLANE_GOOGLE_CLIENT_SECRET=
ARCLANE_GITHUB_CLIENT_ID=
ARCLANE_GITHUB_CLIENT_SECRET=

# Privacy
ARCLANE_PUBLIC_LIVE_FEED_IDENTITY=false
ARCLANE_PUBLIC_LIVE_FEED_DETAIL=false

# Monitoring
# ARCLANE_SENTRY_DSN=https://...@sentry.io/...

# Scheduler
ARCLANE_NIGHTLY_HOUR=2
ARCLANE_NIGHTLY_MINUTE=0
