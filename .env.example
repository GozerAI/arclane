# Arclane Configuration
# All vars prefixed with ARCLANE_ (matches ArclaneSettings env_prefix)
# Copy to .env and fill in values

# Environment (development | production)
ARCLANE_ENV=production

# Database (SQLite for dev, PostgreSQL for prod)
ARCLANE_DATABASE_URL=sqlite+aiosqlite:///arclane.db
# ARCLANE_DATABASE_URL=postgresql+asyncpg://arclane:password@postgres:5432/arclane

# Security — REQUIRED in production (generate: openssl rand -hex 32)
ARCLANE_SECRET_KEY=change-me-in-production

# Domain
ARCLANE_DOMAIN=arclane.cloud
ARCLANE_CADDY_ADMIN_URL=http://localhost:2019

# C-Suite engine (required — the AI backend)
ARCLANE_CSUITE_BASE_URL=http://csuite:8007

# Upstream services
ARCLANE_ZUULTIMATE_BASE_URL=http://zuultimate:8000
ARCLANE_VINZY_BASE_URL=http://vinzy:8001
ARCLANE_TRENDSCOPE_BASE_URL=http://trendscope:8002
ARCLANE_ZUUL_SERVICE_TOKEN=

# Webhook HMAC signing secret (optional — enhances webhook security)
ARCLANE_WEBHOOK_SIGNING_SECRET=

# Stripe billing (via Vinzy provisioning)
ARCLANE_STRIPE_ENABLED=false

# Email (Resend)
ARCLANE_RESEND_API_KEY=
ARCLANE_EMAIL_FROM_DOMAIN=arclane.cloud

# Scheduler (nightly autonomous cycle)
ARCLANE_NIGHTLY_HOUR=2
ARCLANE_NIGHTLY_MINUTE=0

# Error tracking (optional — Sentry)
# ARCLANE_SENTRY_DSN=https://...@sentry.io/...

# Credits
ARCLANE_MONTHLY_CREDITS=5
ARCLANE_FIRST_MONTH_BONUS=10
