# ─────────────────────────────────────────────────────────────
# Stripe Connect Sample — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your Stripe secret key (required).
# Get it from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook signing secret for thin events (V2 account changes).
# Get it from: Stripe Dashboard > Developers > Webhooks
# Or from the output of: stripe listen --thin-events ...
STRIPE_WEBHOOK_SECRET_CONNECT=whsec_REPLACE_ME

# Webhook signing secret for standard subscription events.
# Get it from: Stripe Dashboard > Developers > Webhooks
# Or from the output of: stripe listen --forward-to ...
STRIPE_WEBHOOK_SECRET_SUBSCRIPTIONS=whsec_REPLACE_ME

# Price ID for the platform subscription product.
# Create a product in: https://dashboard.stripe.com/products
# Then copy the price ID (starts with price_).
PLATFORM_PRICE_ID=price_REPLACE_ME

# The public URL of this application (used for redirect URLs).
# Change this when deploying to production.
BASE_URL=http://localhost:8080
